# ==========================================
# 运动会管理系统 - 环境变量配置模板
# 部署时复制为 .env 并修改实际值
# ==========================================

# 服务端口
PORT=3000

# JWT 密钥（生产环境请修改为强随机字符串）
JWT_SECRET=sports_meet_secret_key_2026

# 数据库路径（SQLite）
DATABASE_URL="file:./prisma/dev.db"

# 管理员账号（首次启动自动创建）
ADMIN_EMAIL=admin@hkms.hktedu.com
ADMIN_PASSWORD=admin123
ADMIN_NAME=系统管理员

# 邮件配置（忘记密码功能，可选）
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# 网站信息
SITE_NAME=学校运动会管理系统
SITE_URL=http://localhost:3000
TIMEZONE=Asia/Shanghai

# 报名规则
MAX_EVENTS_PER_STUDENT=3
SESSION_HOURS=24
