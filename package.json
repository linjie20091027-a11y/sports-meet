{
  "name": "sports-meet-manager",
  "version": "2.0.0",
  "description": "澳门濠江中学运动会管理系统 - Prisma ORM版",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "db:migrate": "npx prisma migrate dev --name init",
    "db:seed": "node prisma/seed.js",
    "db:studio": "npx prisma studio",
    "db:reset": "npx prisma migrate reset --force"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "express": "^4.18.2",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "xlsx": "^0.18.5",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "cors": "^2.8.5",
    "svg-captcha": "^1.4.0",
    "cookie-parser": "^1.4.6",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "prisma": "^6.0.0"
  }
}
